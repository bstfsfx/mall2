// ==========================================
// mall2 Prisma Schema
// Maps to existing Supabase PostgreSQL tables
// ==========================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---- Profiles (extends Supabase auth.users) ----
model Profile {
  id         String   @id @db.Uuid
  role       String   @default("customer")
  name       String?
  phone      String?
  address    String?
  created_at DateTime @default(now()) @db.Timestamptz

  orders Order[]

  @@map("profiles")
}

// ---- Categories ----
model Category {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name       String
  slug       String   @unique
  image_url  String?
  created_at DateTime @default(now()) @db.Timestamptz

  products Product[]

  @@map("categories")
}

// ---- Products ----
model Product {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  category_id String?  @db.Uuid
  name        String
  slug        String   @unique
  description String?
  price       Decimal  @default(0.00) @db.Decimal(10, 2)
  stock       Int      @default(0)
  image_url   String?
  images      Json     @default("[]")
  status      String   @default("draft")
  created_at  DateTime @default(now()) @db.Timestamptz

  category    Category?   @relation(fields: [category_id], references: [id], onDelete: SetNull)
  order_items OrderItem[]

  @@map("products")
}

// ---- Orders ----
model Order {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id          String?  @db.Uuid
  status           String   @default("pending")
  total_amount     Decimal  @default(0.00) @db.Decimal(10, 2)
  shipping_address String?
  created_at       DateTime @default(now()) @db.Timestamptz

  // Payment and Logistics Fields
  shipping_method  String?
  shipping_fee     Decimal  @default(0.00) @db.Decimal(10, 2)
  payment_method   String?
  payment_status   String   @default("unpaid")
  shipping_status  String   @default("pending")
  tracking_number  String?
  payment_details  Json     @default("{}")

  user  Profile?    @relation(fields: [user_id], references: [id], onDelete: SetNull)
  items OrderItem[]

  @@map("orders")
}

// ---- Order Items ----
model OrderItem {
  id            String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  order_id      String? @db.Uuid
  product_id    String? @db.Uuid
  quantity      Int     @default(1)
  price_at_time Decimal @db.Decimal(10, 2)

  order   Order?   @relation(fields: [order_id], references: [id], onDelete: Cascade)
  product Product? @relation(fields: [product_id], references: [id], onDelete: SetNull)

  @@map("order_items")
}

// ---- Discount Codes ----
model DiscountCode {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code           String   @unique @db.VarChar(50)
  name           String   @db.VarChar(100)
  description    String?
  discount_type  String   @db.VarChar(20)
  discount_value Decimal  @default(0.00) @db.Decimal(10, 2)
  min_order_amount Decimal @default(0.00) @db.Decimal(10, 2)
  max_uses       Int?
  used_count     Int      @default(0)
  start_date     DateTime @default(now()) @db.Timestamptz
  end_date       DateTime? @db.Timestamptz
  is_active      Boolean  @default(true)
  created_at     DateTime @default(now()) @db.Timestamptz
  updated_at     DateTime @default(now()) @db.Timestamptz

  @@map("discount_codes")
}
